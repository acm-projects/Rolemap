{
  "Rolemap_Architecture": {
      "1_Neo4j_Global_Knowledge_Graph": {
    "Purpose": "Holds the universal truths, professional dependencies, and taxonomy. It remains strictly stateless regarding individual users.",
    "Nodes": {
      "Job": {
        "id": "UUID",
        "display_name": "String",
        "description": "String"
      },
      "Domain": {
        "id": "UUID",
        "name": "String"
      },
      "Concept": {
        "id": "UUID",
        "name": "String"
      },
      "Tool": {
        "id": "UUID",
        "name": "String"
      },
      "Resource": {
        "id": "UUID",
        "url": "String",
        "format": "String"
      }
    },
    "Edges": [
      "(Job) -[REQUIRES {weight: Float, is_core: Boolean}]-> (Concept)",
      "(Concept) -[PREREQUISITE_FOR]-> (Concept)",
      "(Concept) -[PART_OF]-> (Domain)",
      "(Tool) -[IMPLEMENTS {industry_standard: Boolean, deprecated: Boolean}]-> (Concept)",
      "(Resource) -[TEACHES]-> (Concept)",
      "(Resource) -[TEACHES]-> (Tool)"
    ]
  },
    "2_PostgreSQL_Relational_Game_Engine": {
      "Purpose": "Handles user authentication, the static React Flow UI structure, and the fast-changing game state.",
      "Tables": {
        "Users": {
          "Purpose": "Handles core authentication and profile data",
          "Columns": {
            "user_id": "PK (UUID)",
            "username": "Varchar",
            "password_hash": "Varchar",
            "github_token": "Encrypted Varchar",
            "created_at": "Timestamp"
          }
        },
        "User_Roadmaps": {
          "Purpose": "Stores the static structural layout generated by AI agents",
          "Columns": {
            "roadmap_id": "PK (UUID)",
            "user_id": "FK (UUID)",
            "target_job_id": "String (References Neo4j Job ID)",
            "ui_layout": {
              "DataType": "JSONB",
              "Purpose": "Stores ONLY the node coordinates, IDs, and edges required by React Flow",
              "Schema_Example": {
                "nodes": [
                  {
                    "id": "skill_python",
                    "type": "customSkillNode",
                    "position": {
                      "x": 250,
                      "y": 0
                    },
                    "data": {
                      "label": "Python",
                      "category": "language",
                      "ui_theme": "blue (Strictly use black, white, blue, or green)"
                    }
                  }
                ]
              }
            },
            "is_active": "Boolean"
          }
        },
        "User_Skill_State": {
          "Purpose": "The high-frequency update table where the RPG mechanics live",
          "Columns": {
            "state_id": "PK (UUID)",
            "user_id": "FK (UUID)",
            "node_id": "String (Matches ID in ui_layout JSONB and Neo4j)",
            "proficiency_level": "Float (The user's Y variable)",
            "health": "Int (Used for the decay mechanic)",
            "last_practiced_at": "Timestamp",
            "times_practiced": "Int"
          }
        }
      }
    }
  }
}

